{
  "title": "Calculator Phase 2 Async Overview",
  "uid": "calc-phase2",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"],
    "time_options": ["15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Job Throughput",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum by (queue)(rate(jobs_enqueued_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Success Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "1 - (sum(rate(jobs_failed[5m])) / sum(rate(jobs_enqueued_total[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Jobs In Progress",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum(jobs_in_progress)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Queue Depth by Queue",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "queue_depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Task Runtime P50/P95",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, task)(rate(celery_task_runtime_seconds_bucket[5m])))",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, task)(rate(celery_task_runtime_seconds_bucket[5m])))",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {
          "fields": "",
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Queue Wait P50/P95",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, queue)(rate(job_wait_time_seconds_bucket[5m])))",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, queue)(rate(job_wait_time_seconds_bucket[5m])))",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {
          "fields": "",
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "WebSocket Clients & Errors",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum(ws_clients)",
          "refId": "A",
          "legendFormat": "clients"
        },
        {
          "expr": "rate(ws_send_errors_total[5m])",
          "refId": "B",
          "legendFormat": "send errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": []
  }
}
