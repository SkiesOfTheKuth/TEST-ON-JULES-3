# Flask configuration
FLASK_SECRET_KEY=change-me
LOG_LEVEL=INFO
CALCULATOR_ALLOW_INSECURE_SECRET=false

# API configuration
CALCULATOR_API_KEY=
CALCULATOR_RATE_LIMIT=60/minute
CALCULATOR_MAX_RUNTIME_SECONDS=0.1
CALCULATOR_MAX_RESULT_MAGNITUDE=1e12
CALCULATOR_MAX_EXPRESSION_LENGTH=256

# Observability
# Set to a directory path (shared tmpfs) when running multiple workers to enable
# metrics aggregation across processes.
PROMETHEUS_MULTIPROC_DIR=
